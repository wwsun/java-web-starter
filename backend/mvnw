#!/bin/sh
# Maven Wrapper script
# Downloads and runs the specified Maven version

set -e

MAVEN_PROJECTBASEDIR="$(cd "$(dirname "$0")" && pwd)"
MAVEN_WRAPPER_PROPERTIES_FILE="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Read distribution URL from properties
MAVEN_DIST_URL=""
if [ -f "$MAVEN_WRAPPER_PROPERTIES_FILE" ]; then
    MAVEN_DIST_URL=$(grep "distributionUrl" "$MAVEN_WRAPPER_PROPERTIES_FILE" | sed 's/distributionUrl=//')
fi

if [ -z "$MAVEN_DIST_URL" ]; then
    MAVEN_DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"
fi

MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.9"
MAVEN_BIN="$MAVEN_HOME/apache-maven-3.9.9/bin/mvn"

if [ ! -f "$MAVEN_BIN" ]; then
    echo "Downloading Maven..."
    mkdir -p "$MAVEN_HOME"
    TMPFILE=$(mktemp /tmp/maven-XXXXXX.zip)
    curl -fsSL "$MAVEN_DIST_URL" -o "$TMPFILE"
    unzip -qo "$TMPFILE" -d "$MAVEN_HOME"
    rm -f "$TMPFILE"
    echo "Maven downloaded to $MAVEN_HOME"
fi

exec "$MAVEN_BIN" "$@"
