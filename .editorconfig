# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java
[*.java]
indent_style = space
indent_size = 4

# XML / POM
[*.{xml,xsd,xsl}]
indent_style = space
indent_size = 4

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Properties
[*.properties]
indent_style = space
indent_size = 2

# Frontend (JS/TS/CSS/HTML/JSON)
[*.{js,jsx,ts,tsx,css,html,json}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Dockerfile
[Dockerfile*]
indent_style = space
indent_size = 2

# Shell
[*.sh]
indent_style = space
indent_size = 2
