# =============================================================
# 环境变量配置示例
# 用法：cp .env.example .env，然后填入真实值
# ⚠️  .env 已加入 .gitignore，请勿将真实密钥提交到版本库
# =============================================================

# ----------------------------------------
# 数据库
# ----------------------------------------
# MySQL root 密码（本地开发默认值：root123456）
MYSQL_ROOT_PASSWORD=change-me-strong-password

# ----------------------------------------
# JWT 签名密钥
# 最小 256 位（32 字节），生成命令：
#   openssl rand -hex 32
# ----------------------------------------
JWT_SECRET=change-me-run-openssl-rand-hex-32

# ----------------------------------------
# Redis 密码
# 留空 = 无密码（本地开发默认）
# 生产环境建议设置强密码
# ----------------------------------------
REDIS_PASSWORD=

# ----------------------------------------
# CORS 允许来源
# 本地开发默认 localhost:5173；部署时改为实际域名
# ----------------------------------------
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
